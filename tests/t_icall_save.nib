// Test: indirect calls must save live caller registers that the extern
// descriptor does not preserve, without saving and restoring the vreg
// defined by a byte return in AL.

pub extern fn target() -> u8 in AL clobbers(CX, DX, SI, DI, FLAGS);

fn caller() -> u16 {
    u16 DI = 0x113B;
    far32 addr = 0xE000:0x0100;
    u8 ch = addr as target from mod();
    return DI + zero_extend(ch);
}
