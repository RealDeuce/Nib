// Test: port_out must use AL for the value, port_in must read into AL.
// OUT always sources from AL/AX, IN always reads into AL/AX.

const PORT_LO = 0x50;
const PORT_HI = 0x51;

fn test_out(val: u8) {
    port_out(0x50, val);
}

fn test_out_accum(divisor: u16 in AX) {
    port_out(PORT_LO, AL);
    port_out(PORT_HI, AH);
}

fn test_out16(divisor: u16 in AX) {
    port_out16(PORT_LO, divisor);
}

fn test_out16_preserves(divisor: u16 in AX) preserves(AX) {
    port_out16(PORT_LO, divisor);
}

fn test_in() -> u8 {
    u8 result = port_in(0x60);
    return result;
}

fn test_in16() -> u16 {
    u16 result = port_in16(PORT_LO);
    return result;
}
