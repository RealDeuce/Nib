// Test: port_out must use AL for the value, port_in must read into AL.
// OUT always sources from AL/AX, IN always reads into AL/AX.

const PORT_LO = 0x50;
const PORT_HI = 0x51;
const PORT_TIMER = 0x53;
const PORT_IRQ_CLEAR = 0x90;
const IRQCLR_F9 = 0x40;

fn test_out(val: u8) {
    port_out(0x50, val);
}

fn test_out_accum(divisor: u16 in AX) {
    port_out(PORT_LO, AL);
    port_out(PORT_HI, AH);
}

fn test_out_live_accum(ticks: u8 in AL) {
    port_out(PORT_IRQ_CLEAR, IRQCLR_F9);
    port_out(PORT_TIMER, ticks);
}

fn test_in_live_accum(data: u8 in AL) {
    const u8 status = port_in(0xC1);
    if ((status & 1) == 0) {
        halt();
    }
    port_out(0xC0, data);
}

fn test_out16(divisor: u16 in AX) {
    port_out16(PORT_LO, divisor);
}

fn test_out16_preserves(divisor: u16 in AX) preserves(AX) {
    port_out16(PORT_LO, divisor);
}

fn test_in() -> u8 {
    u8 result = port_in(0x60);
    return result;
}

fn test_in16() -> u16 {
    u16 result = port_in16(PORT_LO);
    return result;
}

fn test_dynamic(port: u16, val: u8) -> u8 {
    const u8 result = port_in(port + 1);
    port_out(port + 2, val & 0x0F);
    return result;
}

fn test_dynamic16(port: u16, val: u16) -> u16 {
    const u16 result = port_in16(port);
    port_out16(port + 2, val);
    return result;
}
