// Test: indirect far calls through far32 parameters keep segment halves.

pub extern fn tone(divisor: u16 in DX)
    preserves(AX, BX, CX, BP, DS, ES, SS);

pub extern fn on()
    preserves(AX, BX, CX, DX, BP, DS, ES, SS);

pub extern fn off()
    preserves(AX, BX, CX, DX, BP, DS, ES, SS);

fn beep_once(tone_addr: far32, on_addr: far32, off_addr: far32,
             divisor: u16) {
    tone_addr as tone from mod(divisor);
    on_addr as on from mod();
    off_addr as off from mod();
}

fn caller() {
    far32 tone_addr = 0xE000:0x0100;
    far32 on_addr = 0xE000:0x0120;
    far32 off_addr = 0xE000:0x0140;

    beep_once(tone_addr, on_addr, off_addr, 440);
    beep_once(tone_addr, on_addr, off_addr, 660);
}
