// Library module: provides a function and extern descriptor

fn do_greet(msg: u16 in SI, len: u16 in CX) {
    nop();
}

// Calling convention descriptor for indirect callers
pub extern fn greet(msg: u16 in SI, len: u16 in CX)
    clobbers(AX, CX, SI, DI, FLAGS);

pub extern fn far read_time(dst: far32 in ES:SI)
    ds(0x0000)
    clobbers(FLAGS);
