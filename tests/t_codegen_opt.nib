// Test: generic binder codegen optimizations for direct branches and
// in-place updates.

fn branch_to_goto(x: u16) -> u16 {
    if (x == 0) {
        goto zero;
    }
    return 1;
zero:
    return 0;
}

fn count_down(n: u16) -> u16 {
loop:
    n := n - 1;
    if (n != 0) {
        goto loop;
    }
    return n;
}

fn bump(x: u16) -> u16 {
    x := x + 1;
    return x;
}

fn assume_branch(x: u16) -> u16 {
    assume(x == 0);
    if (x == 0) {
        goto zero;
    }
    return 1;
zero:
    return 0;
}
