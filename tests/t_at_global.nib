// Test: global with at() placement followed by non-at() items
// at() pushes location. Only explicit end at; or module boundary pops.

at(0x1000:0x0000);

fn before() {
    nop();
}

// Detour to 0:0 — counter should follow table at 0:8
at(0x0000:0x0000);
u16[4] table;

// counter follows table because no end at; was issued
u16 counter;

// Pop back to 1000:xxxx for the rest
end at;

fn after() {
    nop();
}
