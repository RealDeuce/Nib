// Test: extern function declarations

extern fn far [0xF000:0x0050] rom_read(port: u16 in DX) -> u16 in AX
    clobbers(DX, FLAGS);

extern fn far [0xF000:0x0100] rom_init()
    clobbers(AX, CX, DX, BX, SI, DI, FLAGS);

extern fn far [0xF000:0x0080] dos_putchar(
    svc: u8 in AH,
    char: u8 in DL
) clobbers(AX, DX, FLAGS);

fn test_extern() {
    u16 DX = 0x03F8;
    u16 val = rom_read(DX);
    rom_init();
    dos_putchar(0x02, 0x41);
}
