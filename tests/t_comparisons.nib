// Test: comparison operators (unsigned and signed)

fn unsigned_comparisons(a: u16, b: u16) -> u16 {
    if (a == b) { return 0; }
    if (a != b) { return 1; }
    if (a > b)  { return 2; }
    if (a < b)  { return 3; }
    if (a >= b) { return 4; }
    if (a <= b) { return 5; }
    return 6;
}

fn signed_comparisons(a: u16, b: u16) -> u16 {
    if (a $> b)  { return 0; }
    if (a $< b)  { return 1; }
    if (a $>= b) { return 2; }
    if (a $<= b) { return 3; }
    return 4;
}

fn compare_with_literal(x: u16) -> u16 {
    if (x == 0)   { return 0; }
    if (x > 100)  { return 1; }
    if (x < 10)   { return 2; }
    return 3;
}

fn compare_bytes(a: u8, b: u8) -> u8 {
    if (a == b) { return 1; }
    return 0;
}
